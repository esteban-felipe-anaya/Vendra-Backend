# Vendra backend (Spring Boot) — copy to .env and fill. NEVER commit the real .env.

# --- Supabase project ---
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_REF=YOUR_REF
SUPABASE_ANON_KEY=eyJhbGciOi...                      # public anon key (clients use this)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...              # SECRET — server-side only, bypasses RLS

# --- JWT verification (OAuth2 Resource Server) ---
# Asymmetric (default): Spring verifies via JWKS.
SUPABASE_JWKS_URI=https://YOUR_REF.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://YOUR_REF.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
# Legacy HS256 fallback (only if project still uses shared-secret JWTs):
SUPABASE_JWT_SECRET=

# --- Database (JDBC, service credentials, bypasses RLS) ---
# Use the Supabase connection pooler (port 6543) for app workloads.
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.YOUR_REF
SPRING_DATASOURCE_PASSWORD=YOUR_DB_PASSWORD

# --- Storage ---
SUPABASE_STORAGE_URL=https://YOUR_REF.supabase.co/storage/v1
SUPABASE_BUCKET_PRODUCTS=products
SUPABASE_BUCKET_SHOPS=shops
SUPABASE_BUCKET_AVATARS=avatars

# --- Stripe Connect (TEST MODE) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/merchant/onboarding/refresh
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/merchant/onboarding/return

# --- App ---
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
